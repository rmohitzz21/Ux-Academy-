# ========================================
# UX Academy - Backend Directory Protection
# ========================================

# Deny direct access to all PHP files in this directory
<FilesMatch "\.(php)$">
    Deny from all
</FilesMatch>

# Specifically allow form handler if using mod_rewrite
# This prevents direct browser access but allows internal requests
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^(.*)$ - [F]
</IfModule>
