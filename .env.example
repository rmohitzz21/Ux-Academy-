# ========================================
# UX Academy PHP - Environment Configuration Template
# Copy this file to .env and update values
# EMAIL-ONLY MODE (No Database Required)
# ========================================

# Site Configuration
SITE_NAME=UX Pacific Academy
SITE_URL=http://localhost/Ux/Ux-Academy-
ADMIN_EMAIL=hello@uxpacific.com
ADMIN_NAME=UX Pacific

# Email Configuration (SMTP)
# Option 1: Using Mailtrap (recommended for testing)
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password

# Option 2: Using Gmail (requires app password)
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password

# Option 3: Using SendGrid
# MAIL_HOST=smtp.sendgrid.net
# MAIL_PORT=587
# MAIL_USERNAME=apikey
# MAIL_PASSWORD=SG.your-sendgrid-key

MAIL_FROM_EMAIL=noreply@uxpacific.com
MAIL_FROM_NAME=UX Pacific Academy
MAIL_ENCRYPTION=tls

# Form Security
FORM_RATE_LIMIT_MINUTES=1
FORM_RATE_LIMIT_SUBMISSIONS=1

# Environment (development or production)
ENVIRONMENT=development
DEBUG=true
LOG_ERRORS=true

# Session Configuration
SESSION_LIFETIME=3600
CSRF_TOKEN_LENGTH=32

# ========================================
# IMPORTANT NOTES:
# ========================================
# 1. Copy this file to .env and update values
# 2. Keep MAIL_PASSWORD secure, don't share publicly
# 3. Set DEBUG=false in production
# 4. Change SITE_URL for production domain
# 5. Update ADMIN_EMAIL to your real email
# 6. No database setup needed!
# 7. Forms send emails only (no storage)
# 8. Logs are saved to /logs/ directory

